{
  "name": "@xo/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate deploy --config prisma.config.ts",
    "prisma:studio": "prisma studio --config prisma.config.ts",
    "seed": "tsx prisma/seed.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "dotenv": "latest",
    "bcryptjs": "latest",
    "@prisma/adapter-mariadb": "7.8.0",
    "mariadb": "latest"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "tsx": "latest",
    "typescript": "latest",
    "@types/bcryptjs": "latest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
