# Copy this file to .env at the repository root before running migrations/server.
# MySQL examples:
# mysql://root:password@localhost:3306/xo_arena
# mysql://root:@localhost:3306/xo_arena
DATABASE_URL="mysql://root:password@localhost:3306/xo_arena"

# Server
NODE_ENV="development"
PORT="4000"
APP_ORIGIN="http://localhost:3000"
API_BASE_URL="http://localhost:4000"
SESSION_COOKIE_NAME="xo_session"
SESSION_TTL_DAYS="30"
UPLOAD_DIR="uploads"

# Email verification via SMTP.
# For local development, leave these empty and the backend prints verification links in the terminal.
# For real email, use any free SMTP you can access, e.g. Gmail app password, Brevo free SMTP, Mailtrap free dev inbox.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="XO Arena <no-reply@xo-arena.local>"

# Web app
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_SOCKET_URL="http://localhost:4000"
